<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RootNamespace>RefinedElement.Kentico.Sentinel.XbyK.Admin</RootNamespace>
    <AssemblyName>RefinedElement.Kentico.Sentinel.XbyK.Admin</AssemblyName>

    <PackageId>RefinedElement.Kentico.Sentinel.XbyK.Admin</PackageId>
    <Version>0.4.2-alpha</Version>
    <Authors>Refined Element</Authors>
    <Company>Refined Element</Company>
    <Description>Admin UI for Kentico Sentinel. Adds a "Sentinel" application under Configuration in the Kentico admin — Dashboard with KPI tiles + recent scans + top rule offenders, Findings listing, Scan history listing, and an in-admin "Request a quote" contact form that submits sanitized scans to Refined Element. Ships alongside RefinedElement.Kentico.Sentinel.XbyK; headless installs that don't want the admin surface can omit this package.</Description>
    <PackageTags>xperience-by-kentico;xbyk;kentico;admin-ui;dashboard;monitoring;health-check</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/refined-element/kentico-sentinel</PackageProjectUrl>
    <RepositoryUrl>https://github.com/refined-element/kentico-sentinel</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!--
      AdminOrgName identifies the org that publishes this admin client bundle. Combined with the
      ProjectName on <AdminClientPath> below, it forms the "org-project" key Kentico's admin
      shell uses to register the module. Must match, verbatim, the same pair of strings in four
      other places — SentinelAdminModule.RegisterClientModule(...), the webpack config, and the
      templateName prefix on every [UIPage] attribute. Any drift renders a blank admin page.
    -->
    <AdminOrgName>refinedelement</AdminOrgName>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <!-- References the XbyK integration package (via ProjectReference while both live in this
         solution; when published the NuGet manifest lists it as a regular package dependency). -->
    <ProjectReference Include="..\KenticoSentinel.XbyK\KenticoSentinel.XbyK.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Kentico.Xperience.Admin transitively pulls Core and WebApp, so we don't re-reference those
      here. Admin package major version must line up with the platform — pin to 31.x the same way
      the main integration package does, reject 32.x automatic updates until we've verified the
      admin surface still compiles.
    -->
    <PackageReference Include="Kentico.Xperience.Admin" Version="[31.0.0,32.0.0)" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Kentico's startup attribute scanner only inspects assemblies flagged as discoverable. Without
      this, [UIApplication] and [UIPage] attributes are never discovered and the Sentinel nav entry
      silently fails to appear in admin — same failure mode as the scheduled-task registration bug
      we fixed in v0.2.1-alpha on the main integration package.
    -->
    <AssemblyAttribute Include="CMS.AssemblyDiscoverableAttribute" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Keep the client source out of the C# compile set — it lives in its own npm workspace under
      Client/. Without these Removes, MSBuild would pick up .tsx files (treating them as C#) and
      node_modules/ would flood the Compile inputs. The bundle output is consumed via a dynamic
      <AdminClientPath> ItemGroup populated INSIDE the SentinelAdminBuildClientBundle target
      below — not a static one at project-load time, because that's when the dist/ glob would
      evaluate empty on a fresh clone / clean CI and no bundle would ever get embedded.
    -->
    <None Remove="Client\**" />
    <Compile Remove="Client\**" />
    <EmbeddedResource Remove="Client\**" />
  </ItemGroup>

  <!--
    Auto-run the client build before Kentico's admin-resource embedding so `dotnet build` on a
    fresh clone produces a runnable assembly. Embedded mode reads Client/dist/** via the
    @(AdminClientPath) ItemGroup, which Kentico's IncludeEmbededResource target scans during
    PrepareForBuild; if dist/ is empty at that moment — or if the ItemGroup was evaluated at
    project-load time when dist/ didn't exist yet — no bundle ships and the admin page renders
    blank at runtime with a SystemJS "Error#3".

    Two precautions required, both learned the hard way on v0.3.0-alpha:

      1. BeforeTargets="IncludeEmbededResource" (not just "PrepareForBuild" or "BeforeBuild").
         When two targets share a BeforeTargets value, MSBuild doesn't guarantee execution
         order between them — so "BeforeTargets=PrepareForBuild" alongside Kentico's own
         "BeforeTargets=PrepareForBuild" is a coin flip. Hooking directly before
         IncludeEmbededResource pins the order deterministically.

      2. The @(AdminClientPath) ItemGroup is populated INSIDE this target, not at project
         load. Static ItemGroups with glob Includes evaluate once when MSBuild loads the
         project file; if dist/ is empty at that instant, the items resolve to an empty list
         and stay empty no matter what subsequent targets produce. Populating inside the
         target forces the glob to re-evaluate against the post-build filesystem.

    Release config -> production webpack bundle (minified). Debug config -> development
    bundle (readable sources for in-browser debugging). Both write to Client/dist/.
  -->
  <Target Name="SentinelAdminNpmInstall" BeforeTargets="IncludeEmbededResource" Condition="!Exists('Client/node_modules')">
    <!-- Forward slash path — Linux CI runners treat 'Client\node_modules' as literally that
         filename (never exists), which would force npm ci on every build and turn a cached
         step into a multi-minute one. Cross-platform path keeps the incremental-build win. -->
    <Message Importance="high" Text="Installing Sentinel admin client npm dependencies (first build only)..." />
    <Exec Command="npm ci" WorkingDirectory="Client" ContinueOnError="false" />
  </Target>

  <Target Name="SentinelAdminBuildClientBundle" BeforeTargets="IncludeEmbededResource" DependsOnTargets="SentinelAdminNpmInstall">
    <Message Importance="high" Text="Building Sentinel admin client bundle (mode=$(Configuration))..." />
    <Exec Command="npm run build" WorkingDirectory="Client" Condition="'$(Configuration)' == 'Release'" ContinueOnError="false" />
    <Exec Command="npm run build:dev" WorkingDirectory="Client" Condition="'$(Configuration)' != 'Release'" ContinueOnError="false" />

    <!-- Now that dist/ exists, register its contents with @(AdminClientPath). Kentico's
         IncludeEmbededResource target runs next and transforms these items into
         EmbeddedResource entries keyed by AdminResources/{orgName}.{projectNameDotted}/{filename},
         where projectNameDotted is the ProjectName with dashes replaced by dots (Kentico's
         target calls .Replace('-','.') on the value — see the Kentico.Xperience.Admin.targets
         file). So ProjectName="sentinel-admin" produces the runtime URL
         "/admin/adminresources/refinedelement.sentinel.admin/entry.js". ProjectName must
         match the webpack config's projectName exactly — the transformation only happens on
         the MSBuild side, not on the admin shell's resolution side. -->
    <ItemGroup>
      <AdminClientPath Include="Client\dist\**">
        <ProjectName>sentinel-admin</ProjectName>
      </AdminClientPath>
    </ItemGroup>
  </Target>

</Project>
