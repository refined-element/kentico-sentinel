{
  "name": "sentinel-admin",
  "version": "0.3.0",
  "private": true,
  "description": "React client for the Kentico Sentinel admin UI (Dashboard, Scan detail, Diff, Settings, Contact form).",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && webpack --mode production",
    "build:dev": "tsc --noEmit && webpack --mode development",
    "watch": "webpack --mode development --watch"
  },
  "dependencies": {
    "@kentico/xperience-admin-base": "^31.0.0",
    "@kentico/xperience-admin-components": "^31.0.0"
  },
  "devDependencies": {
    "@kentico/xperience-webpack-config": "^31.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  }
}
